npx lint-staged

# Backend convention guard: run the Python module-docstring + reference check on
# any staged backend/*.py files. Scoped to staged files only so it stays fast;
# no-op when the commit touches no backend Python.
ROOT="$(git rev-parse --show-toplevel)"
STAGED_PY_FULL="$(git diff --cached --name-only --diff-filter=ACM -- 'backend/**/*.py')"
STAGED_PY="$(echo "$STAGED_PY_FULL" | sed 's|^backend/||')"

if [ -n "$STAGED_PY" ]; then
  echo "husky - running backend convention guard on staged .py files"
  ( cd "$ROOT/backend" && uv run python scripts/check_conventions.py $STAGED_PY )

  # Repo-level .pre-commit-config.yaml (ported from snacks) — ruff + ruff-format
  # + basedpyright on staged backend .py files. Invoked directly (not via
  # `pre-commit install`) so husky stays the single git-hook owner.
  echo "husky - running pre-commit (ruff + basedpyright) on staged backend .py files"
  ( cd "$ROOT" && pre-commit run --files $STAGED_PY_FULL )
fi
