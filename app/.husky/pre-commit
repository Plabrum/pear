npx lint-staged

# Backend convention guard: run the Python module-docstring + reference check on
# any staged backend/*.py files. Scoped to staged files only so it stays fast;
# no-op when the commit touches no backend Python.
ROOT="$(git rev-parse --show-toplevel)"
STAGED_PY="$(git diff --cached --name-only --diff-filter=ACM -- 'backend/**/*.py' | sed 's|^backend/||')"

if [ -n "$STAGED_PY" ]; then
  echo "husky - running backend convention guard on staged .py files"
  ( cd "$ROOT/backend" && uv run python scripts/check_conventions.py $STAGED_PY )
fi
