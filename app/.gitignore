# Learn more https://docs.github.com/en/get-started/getting-started-with-git/ignoring-files

# dependencies
node_modules/

# Expo
.expo/
dist/
web-build/
expo-env.d.ts

# Native
.kotlin/
*.orig.*
*.jks
*.p8
*.p12
*.key
*.mobileprovision

# Metro
.metro-health-check*

# debug
npm-debug.*
yarn-debug.*
yarn-error.*

# macOS
.DS_Store
*.pem
# ...except the committed OTA code-signing PUBLIC certificate (no private key
# material — see ios/Pear/OTA/README.md).
!ios/Pear/OTA/updates-signing.pem

# local env files
.env*.local
.env.production
.secrets

# typescript
*.tsbuildinfo

app-example

# android — pure CNG, generated on demand
/android

# ios/ — hand-maintained native project for Xcode Cloud, except everything XcodeGen
# generates from ios/project.yml (`xcodegen generate && pod install`, or
# `npm run dev:sim`, which does this automatically): the Xcode project itself, plus
# Info.plist and Pear.entitlements, whose content now lives in project.yml's
# info.properties/entitlements.properties.
ios/Pods/
ios/build/
ios/DerivedData/
ios/*.xcuserstate
**/xcuserdata/
ios/Pear.xcodeproj/
ios/Pear.xcworkspace/
ios/Pear/Info.plist
ios/Pear/Pear.entitlements

# fingerprint cache (local build state)
.build-fingerprint
.dev-sim-rev

# drizzle-kit introspect artifacts (we only commit schema.ts + relations.ts)
.drizzle/

# Design reference screenshots (local-only, not committed)
design/screens/
