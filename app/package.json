{
  "name": "pear",
  "main": "index.js",
  "version": "1.0.22",
  "scripts": {
    "postinstall": "patch-package",
    "dev:sim": "bash scripts/dev-sim.sh",
    "export:ota": "node scripts/export-ota-bundle.js",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "api:spec": "cd ../backend && uv run litestar --app app.index:app schema openapi --output ../app/openapi.json && cd ../app && prettier --write openapi.json",
    "api:gen": "orval --config orval.config.ts",
    "codegen": "npm run api:spec && npm run api:gen",
    "prebuild:local": "bash scripts/check-local-build-deps.sh",
    "build:device": "open ios/Pear.xcworkspace"
  },
  "dependencies": {
    "@bam.tech/react-native-image-resizer": "^3.0.11",
    "@gorhom/bottom-sheet": "^5.2.14",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-community/blur": "^4.4.1",
    "@react-native-community/datetimepicker": "9.1.0",
    "@react-navigation/bottom-tabs": "^7.18.8",
    "@react-navigation/native": "^7.3.8",
    "@react-navigation/native-stack": "^7.17.10",
    "@rn-primitives/dialog": "^1.4.0",
    "@rn-primitives/portal": "^1.4.0",
    "@tanstack/react-query": "^5.90.21",
    "clsx": "^2.1.1",
    "libphonenumber-js": "^1.12.39",
    "nativewind": "^4.2.6",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-hook-form": "^7.71.2",
    "react-native": "0.85.3",
    "react-native-blob-util": "^0.24.10",
    "react-native-contacts": "^8.0.10",
    "react-native-gesture-handler": "~2.31.1",
    "react-native-image-crop-picker": "^0.51.1",
    "react-native-keyboard-controller": "1.21.6",
    "react-native-linear-gradient": "^2.8.3",
    "react-native-reanimated": "4.3.1",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "4.25.2",
    "react-native-svg": "15.15.4",
    "react-native-url-polyfill": "^3.0.0",
    "react-native-vector-icons": "^10.3.0",
    "react-native-web": "~0.21.0",
    "react-native-worklets": "0.8.3",
    "sonner-native": "^0.23.1",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^3.4.19"
  },
  "devDependencies": {
    "@react-native-community/cli": "^20.2.0",
    "@react-native/eslint-config": "^0.85.3",
    "@react-native/typescript-config": "^0.85.3",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/react": "~19.2.14",
    "@types/react-native-vector-icons": "^6.4.18",
    "babel-plugin-transform-inline-environment-variables": "^0.4.4",
    "dotenv": "^17.2.3",
    "eslint": "^9.25.0",
    "jsonwebtoken": "^9.0.3",
    "orval": "^8.8.0",
    "patch-package": "^8.0.1",
    "prettier": "^3.8.1",
    "typescript": "~6.0.3"
  },
  "private": true
}
