{
  "name": "pear",
  "main": "expo-router/entry",
  "version": "1.0.22",
  "scripts": {
    "postinstall": "patch-package",
    "start": "bash scripts/dev.sh",
    "dev:sim": "bash scripts/dev-sim.sh",
    "export:ota": "expo export -p ios",
    "reset-project": "node ./scripts/reset-project.js",
    "web": "expo start --web",
    "lint": "expo lint",
    "typecheck:functions": "cd ../supabase/functions/api && deno check **/*.ts",
    "lint:functions": "cd ../supabase/functions/api && deno lint",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "format:functions": "deno fmt ../supabase/functions",
    "db:up": "bash scripts/db-up.sh",
    "db:down": "bash scripts/db-down.sh",
    "db:reset": "bash scripts/db-reset.sh",
    "db:fixtures": "bash scripts/db-fixtures.sh",
    "db:types": "cd .. && supabase gen types typescript --local > app/types/database.ts",
    "db:drizzle": "drizzle-kit introspect --config drizzle.config.ts",
    "api:serve": "cd .. && supabase functions serve api --env-file app/.env.local --no-verify-jwt",
    "api:spec": "cd ../backend && uv run litestar --app app.index:app schema openapi --output ../app/openapi.json && cd ../app && prettier --write openapi.json",
    "api:gen": "orval --config orval.config.ts",
    "codegen": "npm run api:spec && npm run api:gen",
    "prebuild:local": "bash scripts/check-local-build-deps.sh",
    "build:device": "open ios/Pear.xcworkspace",
    "seed:prod": "npx tsx --env-file .env.local scripts/seed-prod.ts"
  },
  "dependencies": {
    "@bam.tech/react-native-image-resizer": "^3.0.11",
    "@expo-google-fonts/dm-serif-display": "^0.4.2",
    "@expo-google-fonts/geist": "^0.4.1",
    "@gorhom/bottom-sheet": "^5.2.14",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-community/blur": "^4.4.1",
    "@react-native-community/datetimepicker": "9.1.0",
    "@rn-primitives/dialog": "^1.4.0",
    "@rn-primitives/portal": "^1.4.0",
    "@tailwindcss/postcss": "^4.2.1",
    "@tanstack/react-query": "^5.90.21",
    "clsx": "^2.1.1",
    "expo": "^56.0.12",
    "expo-apple-authentication": "~56.0.4",
    "expo-constants": "~56.0.18",
    "expo-dev-client": "~56.0.20",
    "expo-device": "~56.0.4",
    "expo-font": "~56.0.7",
    "expo-haptics": "~56.0.3",
    "expo-notifications": "~56.0.18",
    "expo-router": "~56.2.11",
    "expo-splash-screen": "~56.0.10",
    "expo-system-ui": "~56.0.5",
    "expo-updates": "~56.0.19",
    "expo-web-browser": "~56.0.5",
    "libphonenumber-js": "^1.12.39",
    "nativewind": "^5.0.0-preview.2",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-hook-form": "^7.71.2",
    "react-native": "0.85.3",
    "react-native-blob-util": "^0.24.10",
    "react-native-contacts": "^8.0.10",
    "react-native-css": "^3.0.7",
    "react-native-gesture-handler": "~2.31.1",
    "react-native-image-crop-picker": "^0.51.1",
    "react-native-keyboard-controller": "1.21.6",
    "react-native-linear-gradient": "^2.8.3",
    "react-native-reanimated": "4.3.1",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "4.25.2",
    "react-native-svg": "15.15.4",
    "react-native-url-polyfill": "^3.0.0",
    "react-native-vector-icons": "^10.3.0",
    "react-native-web": "~0.21.0",
    "react-native-worklets": "0.8.3",
    "sonner-native": "^0.23.1",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.1"
  },
  "devDependencies": {
    "@types/jsonwebtoken": "^9.0.10",
    "@types/react": "~19.2.14",
    "@types/react-native-vector-icons": "^6.4.18",
    "drizzle-kit": "^0.31.10",
    "drizzle-orm": "^0.45.2",
    "eslint": "^9.25.0",
    "eslint-config-expo": "~56.0.4",
    "jsonwebtoken": "^9.0.3",
    "orval": "^8.8.0",
    "patch-package": "^8.0.1",
    "postgres": "^3.4.9",
    "prettier": "^3.8.1",
    "supabase": "2.75.0",
    "typescript": "~6.0.3"
  },
  "private": true,
  "overrides": {
    "lightningcss": "1.30.1"
  }
}
